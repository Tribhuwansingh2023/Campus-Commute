BACKEND_PORT=8000

FRONTEND_URL=https://your-frontend.vercel.app

MONGODB_URI="mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority"

JWT_SECRET="your_strong_jwt_secret_here"

# Gmail credentials for SMTP email fallback
EMAIL=your_gmail@gmail.com
EMAIL_PASS="xxxx xxxx xxxx xxxx"    # 16-char Gmail App Password (spaces OK, auto-stripped)

# Resend API Key (PRIMARY email method — HTTP-based, works on Railway/Render/Vercel)
# Sign up FREE at https://resend.com → Dashboard → API Keys → Create Key
# Free tier: 3,000 emails/month, 100/day
RESEND_API_KEY=re_your_resend_api_key_here

GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

GOOGLE_CLIENT_SECRET=your_google_client_secret